{
    "key": "group_showtime_reviews_faq",
    "title": "Reviews & FAQ",
    "fields": [
        {
            "key": "field_st_home_reviews",
            "label": "Homepage reviews",
            "name": "home_reviews",
            "type": "repeater",
            "instructions": "Reviews shown in the homepage carousel. Phase 2B replaces this with a Review CPT auto-imported from Google Business Profile.",
            "min": 0,
            "max": 24,
            "layout": "block",
            "button_label": "Add review",
            "sub_fields": [
                {
                    "key": "field_st_rev_rating",
                    "label": "Rating (1-5)",
                    "name": "rating",
                    "type": "number",
                    "min": 1,
                    "max": 5,
                    "default_value": 5,
                    "wrapper": { "width": "10" }
                },
                {
                    "key": "field_st_rev_name",
                    "label": "Reviewer",
                    "name": "name",
                    "type": "text",
                    "required": 1,
                    "placeholder": "Mark D.",
                    "wrapper": { "width": "20" }
                },
                {
                    "key": "field_st_rev_where",
                    "label": "Where / Service",
                    "name": "where",
                    "type": "text",
                    "placeholder": "Sherman Oaks · weekly service",
                    "wrapper": { "width": "30" }
                },
                {
                    "key": "field_st_rev_date",
                    "label": "Date label",
                    "name": "date",
                    "type": "text",
                    "placeholder": "Apr 2026",
                    "wrapper": { "width": "20" }
                },
                {
                    "key": "field_st_rev_source",
                    "label": "Source",
                    "name": "source",
                    "type": "select",
                    "choices": {
                        "Google": "Google",
                        "Yelp": "Yelp",
                        "Facebook": "Facebook",
                        "Direct": "Direct"
                    },
                    "default_value": "Google",
                    "wrapper": { "width": "20" }
                },
                {
                    "key": "field_st_rev_body",
                    "label": "Review body",
                    "name": "body",
                    "type": "textarea",
                    "rows": 3,
                    "required": 1,
                    "wrapper": { "width": "100" }
                }
            ]
        },
        {
            "key": "field_st_home_faqs",
            "label": "Homepage FAQ",
            "name": "home_faqs",
            "type": "repeater",
            "instructions": "Five FAQ items shown on the homepage with FAQPage JSON-LD schema for SERP rich results.",
            "min": 0,
            "max": 12,
            "layout": "block",
            "button_label": "Add question",
            "sub_fields": [
                {
                    "key": "field_st_faq_q",
                    "label": "Question",
                    "name": "q",
                    "type": "text",
                    "required": 1,
                    "wrapper": { "width": "100" }
                },
                {
                    "key": "field_st_faq_a",
                    "label": "Answer",
                    "name": "a",
                    "type": "textarea",
                    "rows": 4,
                    "required": 1,
                    "wrapper": { "width": "100" }
                }
            ]
        }
    ],
    "location": [
        [
            {
                "param": "options_page",
                "operator": "==",
                "value": "showtime-content-reviews-faq"
            }
        ]
    ],
    "menu_order": 0,
    "position": "normal",
    "style": "default",
    "label_placement": "top",
    "instruction_placement": "label",
    "active": true
}
